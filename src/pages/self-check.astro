---
import CourseLayout from '../layouts/CourseLayout.astro';
import { getCollection } from 'astro:content';
import { moduleNames } from '../config';
import { validateModules, logModuleWarnings, isValidModule } from '../lib/moduleValidation';

const selfchecks = await getCollection('selfchecks', (entry) => !entry.data.draft);

// Validate modules and log warnings
const validation = await validateModules();
logModuleWarnings(validation);

// Filter valid selfchecks only
const validSelfchecks = selfchecks.filter(sc => isValidModule(sc.data.module));

// Group by module
const byModule = new Map();
for (const module of moduleNames) {
  byModule.set(module, []);
}
for (const sc of validSelfchecks) {
  const list = byModule.get(sc.data.module) || [];
  list.push(sc);
  byModule.set(sc.data.module, list);
}

const base = import.meta.env.BASE_URL;
---

<CourseLayout title="自我检测">
  <div class="max-w-2xl mx-auto px-4 py-8">
    <header class="mb-6">
      <h1 class="text-3xl font-bold text-gray-900 mb-3">自我检测</h1>
      <p class="text-gray-600">
        通过主动回忆强化学习效果。基于间隔重复算法，优先复习掌握不牢的知识点。
        <span class="text-sm text-gray-500 block mt-1">快捷键: 空格/回车=翻转, 1=不熟悉, 2=一般, 3=已掌握, →/Enter=下一题</span>
      </p>
    </header>

    <!-- Mode Toggle -->
    <div class="flex gap-2 mb-6 p-1 bg-gray-100 rounded-lg w-fit">
      <button id="mode-study" class="mode-btn px-4 py-2 rounded-md text-sm font-medium transition-all bg-white text-gray-900 shadow-sm" data-mode="study">
        学习模式
      </button>
      <button id="mode-browse" class="mode-btn px-4 py-2 rounded-md text-sm font-medium transition-all text-gray-600 hover:text-gray-900" data-mode="browse">
        浏览模式
      </button>
    </div>

    <!-- Study Mode UI -->
    <div id="study-container" class="">
      <!-- Module Filter for Study -->
      <div class="mb-6">
        <label class="text-sm font-medium text-gray-700 mb-2 block">选择模块</label>
        <select id="study-module-filter" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary">
          <option value="all">全部模块</option>
          {moduleNames.map(module => (
            <option value={module}>{module} ({byModule.get(module)?.length || 0})</option>
          ))}
        </select>
      </div>

      <!-- Session Setup -->
      <div id="session-setup" class="bg-white rounded-xl shadow-sm border border-gray-200 p-8 text-center">
        <div class="text-5xl mb-4">🎯</div>
        <h2 class="text-xl font-semibold text-gray-900 mb-2">开始复习会话</h2>
        <p class="text-gray-600 mb-6">根据你的掌握程度，今天有 <span id="due-count" class="font-semibold text-primary">0</span> 道题待复习</p>
        <div class="flex gap-3 justify-center">
          <button id="start-session" class="px-6 py-3 bg-primary text-white rounded-lg font-medium hover:bg-primary-dark transition-colors">
            开始复习
          </button>
          <button id="start-all" class="px-6 py-3 bg-gray-100 text-gray-700 rounded-lg font-medium hover:bg-gray-200 transition-colors">
            全部打乱练习
          </button>
        </div>
        <div class="mt-6 flex justify-center gap-6 text-sm text-gray-500">
          <div class="flex items-center gap-2">
            <span class="w-3 h-3 rounded-full bg-red-400"></span>
            <span>需复习</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="w-3 h-3 rounded-full bg-yellow-400"></span>
            <span>较生疏</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="w-3 h-3 rounded-full bg-green-400"></span>
            <span>已掌握</span>
          </div>
        </div>
      </div>

      <!-- Active Session -->
      <div id="active-session" class="hidden">
        <!-- Progress Bar -->
        <div class="mb-4">
          <div class="flex justify-between text-sm text-gray-600 mb-2">
            <span>进度 <span id="session-progress">1/10</span></span>
            <span id="session-stats" class="text-gray-500">掌握: 0 | 复习: 0</span>
          </div>
          <div class="h-2 bg-gray-200 rounded-full overflow-hidden">
            <div id="progress-bar" class="h-full bg-primary transition-all duration-300" style="width: 10%"></div>
          </div>
        </div>

        <!-- Single Card -->
        <div id="flashcard" class="bg-white rounded-xl shadow-lg border border-gray-200 overflow-hidden min-h-[320px] relative">
          <!-- Front -->
          <div id="card-front" class="p-8 flex flex-col h-full min-h-[320px]">
            <div class="flex items-center justify-between mb-4">
              <span id="card-module" class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-50 text-blue-700">
                模块
              </span>
              <span id="card-counter" class="text-xs text-gray-400">1 / 10</span>
            </div>
            <div class="flex-1 flex items-center justify-center">
              <h3 id="card-question" class="text-xl font-medium text-gray-900 text-center leading-relaxed">
                加载中...
              </h3>
            </div>
            <button id="reveal-btn" class="w-full py-3 px-4 bg-primary text-white rounded-lg font-medium hover:bg-primary-dark transition-colors flex items-center justify-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
              </svg>
              显示答案 (空格)
            </button>
          </div>

          <!-- Back -->
          <div id="card-back" class="hidden p-8 bg-gray-50 min-h-[320px]">
            <div class="flex items-center justify-between mb-4">
              <span class="text-xs text-gray-500 uppercase tracking-wider font-medium">答案</span>
              <span id="card-counter-back" class="text-xs text-gray-400">1 / 10</span>
            </div>
            <p id="card-answer" class="text-gray-900 font-medium mb-4 text-lg"></p>

            <div class="border-t border-gray-200 pt-4 mt-4">
              <span class="text-xs text-gray-500 uppercase tracking-wider font-medium block mb-2">详细解释</span>
              <p id="card-explanation" class="text-gray-700 text-sm leading-relaxed"></p>
            </div>

            <div id="card-tags" class="mt-4 flex flex-wrap gap-2"></div>

            <div class="mt-6">
              <p class="text-sm text-gray-600 mb-3 text-center">你对这个知识点的掌握程度？</p>
              <div class="flex gap-3">
                <button class="confidence-btn flex-1 py-3 px-3 rounded-lg border-2 border-red-200 text-red-600 text-sm font-medium hover:bg-red-50 transition-colors" data-level="1">
                  <span class="block text-lg mb-1">😵</span>
                  不熟悉 (1)
                </button>
                <button class="confidence-btn flex-1 py-3 px-3 rounded-lg border-2 border-yellow-200 text-yellow-600 text-sm font-medium hover:bg-yellow-50 transition-colors" data-level="2">
                  <span class="block text-lg mb-1">🤔</span>
                  一般 (2)
                </button>
                <button class="confidence-btn flex-1 py-3 px-3 rounded-lg border-2 border-green-200 text-green-600 text-sm font-medium hover:bg-green-50 transition-colors" data-level="3">
                  <span class="block text-lg mb-1">✅</span>
                  已掌握 (3)
                </button>
              </div>
            </div>
          </div>
        </div>

        <!-- Keyboard hint -->
        <p class="text-center text-sm text-gray-400 mt-4">
          快捷键: 1=不熟悉, 2=一般, 3=已掌握, →/Enter=下一题
        </p>
      </div>

      <!-- Session Complete -->
      <div id="session-complete" class="hidden bg-white rounded-xl shadow-sm border border-gray-200 p-8 text-center">
        <div class="text-6xl mb-4">🎉</div>
        <h2 class="text-2xl font-semibold text-gray-900 mb-2">会话完成！</h2>
        <p class="text-gray-600 mb-6">你的学习进度已保存</p>

        <div class="grid grid-cols-3 gap-4 mb-6">
          <div class="p-4 bg-red-50 rounded-lg">
            <div id="stats-hard" class="text-2xl font-bold text-red-600">0</div>
            <div class="text-sm text-red-600">需复习</div>
          </div>
          <div class="p-4 bg-yellow-50 rounded-lg">
            <div id="stats-medium" class="text-2xl font-bold text-yellow-600">0</div>
            <div class="text-sm text-yellow-600">较生疏</div>
          </div>
          <div class="p-4 bg-green-50 rounded-lg">
            <div id="stats-easy" class="text-2xl font-bold text-green-600">0</div>
            <div class="text-sm text-green-600">已掌握</div>
          </div>
        </div>

        <div class="flex gap-3 justify-center">
          <button id="start-new-session" class="px-6 py-3 bg-primary text-white rounded-lg font-medium hover:bg-primary-dark transition-colors">
            继续学习
          </button>
          <button id="end-session" class="px-6 py-3 bg-gray-100 text-gray-700 rounded-lg font-medium hover:bg-gray-200 transition-colors">
            结束
          </button>
        </div>
      </div>
    </div>

    <!-- Browse Mode UI -->
    <div id="browse-container" class="hidden">
      <!-- Module Filter -->
      <div class="mb-6">
        <div class="flex flex-wrap gap-2" id="module-filters">
          <button class="filter-btn active px-4 py-2 rounded-full text-sm font-medium transition-all bg-primary text-white" data-module="all">
            全部
          </button>
          {moduleNames.map(module => (
            <button
              class="filter-btn px-4 py-2 rounded-full text-sm font-medium transition-all bg-gray-100 text-gray-700 hover:bg-gray-200"
              data-module={module}
            >
              {module}
              <span class="ml-1 text-xs text-gray-500">({byModule.get(module)?.length || 0})</span>
            </button>
          ))}
        </div>
      </div>

      <!-- Cards Grid -->
      <div class="grid gap-4" id="cards-container">
        {validSelfchecks.map((sc, index) => (
          <div
            class="selfcheck-card bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden"
            data-module={sc.data.module}
            data-index={index}
            data-slug={sc.slug}
          >
            <div class="card-inner">
              <!-- Front -->
              <div class="card-front p-5">
                <div class="flex items-start justify-between mb-3">
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-50 text-blue-700">
                    {sc.data.module}
                  </span>
                  <span class="text-xs text-gray-400">#{index + 1}</span>
                </div>
                <h3 class="text-base font-medium text-gray-900 mb-3">{sc.data.question}</h3>
                <button class="reveal-btn w-full py-2 px-4 bg-primary text-white rounded-lg font-medium hover:bg-primary-dark transition-colors text-sm">
                  显示答案
                </button>
              </div>

              <!-- Back -->
              <div class="card-back p-5 bg-gray-50 hidden">
                <div class="flex items-start justify-between mb-3">
                  <span class="text-xs text-gray-500 uppercase tracking-wider font-medium">答案</span>
                  <button class="close-btn p-1 text-gray-400 hover:text-gray-600">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                  </button>
                </div>
                <p class="bg-primary/10 border-l-4 border-primary p-4 rounded-r-lg text-lg font-semibold text-primary-dark mb-4">{sc.data.answer}</p>

                <div>
                  <span class="text-xs text-gray-500 uppercase tracking-wider font-medium block mb-2">详细解释</span>
                  <p class="text-base text-gray-800 mt-4">{sc.data.explanation}</p>
                </div>

                {sc.data.tags.length > 0 && (
                  <div class="mt-3 flex flex-wrap gap-2">
                    {sc.data.tags.map(tag => (
                      <span class="px-2 py-1 bg-white rounded text-xs text-gray-600 border border-gray-200">{tag}</span>
                    ))}
                  </div>
                )}

                <div class="mt-4 flex gap-2">
                  <button class="confidence-btn flex-1 py-2 px-2 rounded-lg border-2 border-red-200 text-red-600 text-sm font-medium hover:bg-red-50 transition-colors" data-level="1">
                    不熟
                  </button>
                  <button class="confidence-btn flex-1 py-2 px-2 rounded-lg border-2 border-yellow-200 text-yellow-600 text-sm font-medium hover:bg-yellow-50 transition-colors" data-level="2">
                    一般
                  </button>
                  <button class="confidence-btn flex-1 py-2 px-2 rounded-lg border-2 border-green-200 text-green-600 text-sm font-medium hover:bg-green-50 transition-colors" data-level="3">
                    掌握
                  </button>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Empty State -->
      <div id="empty-state" class="hidden text-center py-12">
        <div class="text-6xl mb-4">🎉</div>
        <h3 class="text-xl font-semibold text-gray-900 mb-2">该模块暂无题目</h3>
        <p class="text-gray-600">请尝试选择其他模块</p>
      </div>
    </div>
  </div>
</CourseLayout>

<script>
  // ==================== Data & Types ====================
  interface CardData {
    slug: string;
    module: string;
    question: string;
    answer: string;
    explanation: string;
    tags: string[];
  }

  interface CardState {
    box: number; // 0=new, 1=learning, 2=review, 3=mastered
    nextReview: number; // timestamp
    reviewCount: number;
    lastRating: number;
  }

  // ==================== Storage Keys ====================
  const STORAGE_KEYS = {
    srs: 'selfcheck-srs',
    mode: 'selfcheck-mode',
    stats: 'selfcheck-stats'
  };

  // ==================== Card Data ====================
  const cardsData: CardData[] = [];

  // ==================== State ====================
  let currentMode: 'study' | 'browse' = 'study';
  let sessionQueue: string[] = [];
  let currentCardIndex = 0;
  let sessionStats = { hard: 0, medium: 0, easy: 0, totalReviewed: 0 };

  // ==================== SRS Functions ====================
  function getSRSData(): Record<string, CardState> {
    const data = localStorage.getItem(STORAGE_KEYS.srs);
    return data ? JSON.parse(data) : {};
  }

  function saveSRSData(data: Record<string, CardState>) {
    localStorage.setItem(STORAGE_KEYS.srs, JSON.stringify(data));
  }

  function getCardState(slug: string): CardState {
    const data = getSRSData();
    return data[slug] || {
      box: 0,
      nextReview: 0,
      reviewCount: 0,
      lastRating: 0
    };
  }

  function calculateNextReview(rating: number, currentState: CardState, inSession: boolean = true): CardState {
    const now = Date.now();
    let newBox = currentState.box;

    // Leitner-style box progression
    if (rating === 1) {
      // Hard: back to box 1
      newBox = 1;
    } else if (rating === 2) {
      // Medium: stay in current or move to box 2
      newBox = Math.max(1, currentState.box);
    } else {
      // Easy: advance one box, max 3
      newBox = Math.min(3, currentState.box + 1);
    }

    // Calculate interval based on box and context
    // In-session: immediate repetition for learning (seconds to minutes)
    // Across sessions: days for long-term retention
    let intervals: number[];
    if (inSession) {
      // During a study session: 3 cards later for hard, end of session for medium, done for easy
      intervals = [0, 3 * 60 * 1000, 30 * 60 * 1000, 24 * 60 * 60 * 1000]; // immediate, 3min, 30min, 1day
    } else {
      // Across sessions: proper spaced repetition
      intervals = [10 * 60 * 1000, 24 * 60 * 60 * 1000, 3 * 24 * 60 * 60 * 1000, 7 * 24 * 60 * 60 * 1000];
    }
    const nextReview = now + intervals[newBox];

    return {
      box: newBox,
      nextReview,
      reviewCount: currentState.reviewCount + 1,
      lastRating: rating
    };
  }

  function rateCard(slug: string, rating: number) {
    const srsData = getSRSData();
    const currentState = getCardState(slug);
    const newState = calculateNextReview(rating, currentState);
    srsData[slug] = newState;
    saveSRSData(srsData);

    // Update session stats
    if (rating === 1) sessionStats.hard++;
    else if (rating === 2) sessionStats.medium++;
    else sessionStats.easy++;
    sessionStats.totalReviewed++;

    // Update display immediately
    updateSessionStatsDisplay();
  }

  function updateSessionStatsDisplay() {
    const statsEl = document.getElementById('session-stats');
    if (statsEl) {
      statsEl.textContent = `掌握: ${sessionStats.easy} | 复习: ${sessionStats.totalReviewed}`;
    }
  }

  function getDueCards(moduleFilter: string = 'all'): CardData[] {
    const now = Date.now();
    return cardsData.filter(card => {
      if (moduleFilter !== 'all' && card.module !== moduleFilter) return false;
      const state = getCardState(card.slug);
      return state.nextReview <= now;
    });
  }

  function getAllCards(moduleFilter: string = 'all'): CardData[] {
    if (moduleFilter === 'all') return [...cardsData];
    return cardsData.filter(card => card.module === moduleFilter);
  }

  // ==================== Mode Switching ====================
  function switchMode(mode: 'study' | 'browse') {
    currentMode = mode;
    localStorage.setItem(STORAGE_KEYS.mode, mode);

    // Update toggle UI
    document.querySelectorAll('.mode-btn').forEach(btn => {
      const isActive = btn.dataset.mode === mode;
      btn.classList.toggle('bg-white', isActive);
      btn.classList.toggle('text-gray-900', isActive);
      btn.classList.toggle('shadow-sm', isActive);
      btn.classList.toggle('text-gray-600', !isActive);
    });

    // Show/hide containers
    document.getElementById('study-container')?.classList.toggle('hidden', mode !== 'study');
    document.getElementById('browse-container')?.classList.toggle('hidden', mode !== 'browse');

    if (mode === 'study') {
      updateDueCount();
    }
  }

  document.querySelectorAll('.mode-btn').forEach(btn => {
    btn.addEventListener('click', () => switchMode(btn.dataset.mode as 'study' | 'browse'));
  });

  // ==================== Study Mode ====================
  function updateDueCount() {
    const moduleFilter = (document.getElementById('study-module-filter') as HTMLSelectElement)?.value || 'all';
    const dueCards = getDueCards(moduleFilter);
    const countEl = document.getElementById('due-count');
    if (countEl) countEl.textContent = String(dueCards.length);
  }

  function startSession(useAll: boolean = false) {
    const moduleFilter = (document.getElementById('study-module-filter') as HTMLSelectElement)?.value || 'all';
    const dueCards = useAll ? getAllCards(moduleFilter) : getDueCards(moduleFilter);

    if (dueCards.length === 0) {
      alert(useAll ? '该模块暂无题目' : '暂无需要复习的题目，选择"全部打乱练习"或更换模块');
      return;
    }

    // Shuffle cards
    sessionQueue = dueCards.map(c => c.slug).sort(() => Math.random() - 0.5);
    currentCardIndex = 0;
    sessionStats = { hard: 0, medium: 0, easy: 0, totalReviewed: 0 };

    // Reset stats display
    updateSessionStatsDisplay();

    // Show active session UI
    document.getElementById('session-setup')?.classList.add('hidden');
    document.getElementById('session-complete')?.classList.add('hidden');
    document.getElementById('active-session')?.classList.remove('hidden');

    showCurrentCard();
  }

  function showCurrentCard() {
    const slug = sessionQueue[currentCardIndex];
    const card = cardsData.find(c => c.slug === slug);
    if (!card) return;

    const state = getCardState(slug);

    // Update UI
    document.getElementById('card-module')!.textContent = card.module;
    document.getElementById('card-counter')!.textContent = `${currentCardIndex + 1} / ${sessionQueue.length}`;
    document.getElementById('card-counter-back')!.textContent = `${currentCardIndex + 1} / ${sessionQueue.length}`;
    document.getElementById('card-question')!.textContent = card.question;
    document.getElementById('card-answer')!.textContent = card.answer;
    document.getElementById('card-explanation')!.textContent = card.explanation;

    // Tags
    const tagsContainer = document.getElementById('card-tags')!;
    tagsContainer.innerHTML = card.tags.map(tag =>
      `<span class="px-2 py-1 bg-white rounded text-xs text-gray-600 border border-gray-200">${tag}</span>`
    ).join('');

    // Reset card state
    document.getElementById('card-front')?.classList.remove('hidden');
    document.getElementById('card-back')?.classList.add('hidden');

    // Update progress
    const progress = ((currentCardIndex) / sessionQueue.length) * 100;
    document.getElementById('progress-bar')!.style.width = `${progress}%`;
    document.getElementById('session-progress')!.textContent = `${currentCardIndex + 1}/${sessionQueue.length}`;

    // Reset confidence buttons
    document.querySelectorAll('#card-back .confidence-btn').forEach(btn => {
      btn.classList.remove('ring-2', 'ring-offset-2', 'ring-primary', 'bg-red-50', 'bg-yellow-50', 'bg-green-50');
    });

    // Highlight previous rating if exists
    if (state.lastRating) {
      const btn = document.querySelector(`#card-back .confidence-btn[data-level="${state.lastRating}"]`);
      btn?.classList.add('ring-2', 'ring-offset-2', 'ring-primary');
    }
  }

  function revealCard() {
    document.getElementById('card-front')?.classList.add('hidden');
    document.getElementById('card-back')?.classList.remove('hidden');
  }

  function nextCard() {
    currentCardIndex++;
    if (currentCardIndex >= sessionQueue.length) {
      completeSession();
    } else {
      showCurrentCard();
    }
  }

  function completeSession() {
    document.getElementById('active-session')?.classList.add('hidden');
    document.getElementById('session-complete')?.classList.remove('hidden');

    // Update stats
    document.getElementById('stats-hard')!.textContent = String(sessionStats.hard);
    document.getElementById('stats-medium')!.textContent = String(sessionStats.medium);
    document.getElementById('stats-easy')!.textContent = String(sessionStats.easy);

    // Update the summary text with total
    const summaryEl = document.querySelector('#session-complete p.text-gray-600');
    if (summaryEl) {
      summaryEl.textContent = `共复习 ${sessionStats.totalReviewed} 道题，学习进度已保存`;
    }

    updateDueCount();
  }

  // Event listeners for study mode
  document.getElementById('study-module-filter')?.addEventListener('change', updateDueCount);
  document.getElementById('start-session')?.addEventListener('click', () => startSession(false));
  document.getElementById('start-all')?.addEventListener('click', () => startSession(true));
  document.getElementById('reveal-btn')?.addEventListener('click', revealCard);
  document.getElementById('start-new-session')?.addEventListener('click', () => startSession(false));
  document.getElementById('end-session')?.addEventListener('click', () => {
    document.getElementById('session-complete')?.classList.add('hidden');
    document.getElementById('session-setup')?.classList.remove('hidden');
    updateDueCount();
  });

  // Confidence buttons in study mode
  document.querySelectorAll('#card-back .confidence-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const slug = sessionQueue[currentCardIndex];
      const level = parseInt(btn.dataset.level || '2');
      rateCard(slug, level);

      // Visual feedback
      document.querySelectorAll('#card-back .confidence-btn').forEach(b => {
        b.classList.remove('ring-2', 'ring-offset-2', 'ring-primary');
      });
      btn.classList.add('ring-2', 'ring-offset-2', 'ring-primary');

      // Spaced repetition: re-insert hard cards into queue
      if (level === 1 && currentCardIndex < sessionQueue.length - 1) {
        // Insert 2-3 cards later for immediate review
        const reinsertIndex = Math.min(currentCardIndex + 3, sessionQueue.length);
        sessionQueue.splice(reinsertIndex, 0, slug);
        // Update progress display
        document.getElementById('session-progress')!.textContent = `${currentCardIndex + 1}/${sessionQueue.length}`;
      }

      // Auto-advance after short delay
      setTimeout(nextCard, 300);
    });
  });

  // ==================== Browse Mode ====================
  const filterBtns = document.querySelectorAll('.filter-btn');
  const browseCards = document.querySelectorAll('.selfcheck-card');
  const emptyState = document.getElementById('empty-state');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => {
        b.classList.remove('active', 'bg-primary', 'text-white');
        b.classList.add('bg-gray-100', 'text-gray-700');
      });
      btn.classList.add('active', 'bg-primary', 'text-white');
      btn.classList.remove('bg-gray-100', 'text-gray-700');

      const module = btn.dataset.module;
      let visibleCount = 0;

      browseCards.forEach(card => {
        if (module === 'all' || card.dataset.module === module) {
          card.classList.remove('hidden');
          visibleCount++;
        } else {
          card.classList.add('hidden');
        }
      });

      emptyState?.classList.toggle('hidden', visibleCount > 0);
    });
  });

  // Card flip in browse mode
  browseCards.forEach(card => {
    const revealBtn = card.querySelector('.reveal-btn');
    const closeBtn = card.querySelector('.close-btn');
    const front = card.querySelector('.card-front');
    const back = card.querySelector('.card-back');

    revealBtn?.addEventListener('click', () => {
      front?.classList.add('hidden');
      back?.classList.remove('hidden');
    });

    closeBtn?.addEventListener('click', () => {
      back?.classList.add('hidden');
      front?.classList.remove('hidden');
    });

    // Confidence buttons in browse mode
    card.querySelectorAll('.confidence-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const slug = card.dataset.slug;
        const level = parseInt(btn.dataset.level || '2');
        if (slug) rateCard(slug, level);

        card.querySelectorAll('.confidence-btn').forEach(b => {
          b.classList.remove('ring-2', 'ring-offset-2', 'ring-primary');
        });
        btn.classList.add('ring-2', 'ring-offset-2', 'ring-primary');
      });
    });
  });

  // ==================== Keyboard Shortcuts ====================
  document.addEventListener('keydown', (e) => {
    if (currentMode !== 'study') return;
    if (document.getElementById('active-session')?.classList.contains('hidden')) return;

    const frontHidden = document.getElementById('card-front')?.classList.contains('hidden');

    if (e.key === ' ' || e.key === 'Enter') {
      e.preventDefault();
      if (!frontHidden) {
        revealCard();
      } else {
        nextCard();
      }
    } else if (e.key === '1' && frontHidden) {
      const slug = sessionQueue[currentCardIndex];
      rateCard(slug, 1);
      // Re-insert hard cards for spaced repetition
      if (currentCardIndex < sessionQueue.length - 1) {
        const reinsertIndex = Math.min(currentCardIndex + 3, sessionQueue.length);
        sessionQueue.splice(reinsertIndex, 0, slug);
        document.getElementById('session-progress')!.textContent = `${currentCardIndex + 1}/${sessionQueue.length}`;
      }
      setTimeout(nextCard, 300);
    } else if (e.key === '2' && frontHidden) {
      const slug = sessionQueue[currentCardIndex];
      rateCard(slug, 2);
      setTimeout(nextCard, 300);
    } else if (e.key === '3' && frontHidden) {
      const slug = sessionQueue[currentCardIndex];
      rateCard(slug, 3);
      setTimeout(nextCard, 300);
    } else if (e.key === 'ArrowRight' && frontHidden) {
      nextCard();
    }
  });

  // ==================== Initialize ====================
  function init() {
    // Load card data from DOM
    document.querySelectorAll('.selfcheck-card').forEach(el => {
      const slug = el.dataset.slug || '';
      const module = el.dataset.module || '';
      const question = el.querySelector('.card-front h3')?.textContent || '';
      const answer = el.querySelector('.card-back p')?.textContent || '';
      const explanation = el.querySelector('.card-back .leading-relaxed')?.textContent || '';
      const tags: string[] = [];
      el.querySelectorAll('.card-back .flex.flex-wrap.gap-2 span').forEach(tagEl => {
        tags.push(tagEl.textContent || '');
      });

      cardsData.push({ slug, module, question, answer, explanation, tags });
    });

    // Load saved mode preference
    const savedMode = localStorage.getItem(STORAGE_KEYS.mode) as 'study' | 'browse' | null;
    switchMode(savedMode || 'study');
  }

  init();
</script>

<style>
  .card-back {
    display: none;
  }

  .card-back:not(.hidden) {
    display: block;
    animation: fadeIn 0.2s ease-out;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .filter-btn.active {
    background-color: var(--color-primary, #3b82f6);
    color: white;
  }

  #flashcard {
    perspective: 1000px;
  }
</style>

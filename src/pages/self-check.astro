---
import CourseLayout from '../layouts/CourseLayout.astro';
import { getCollection } from 'astro:content';
import { moduleNames } from '../config';
import { validateModules, logModuleWarnings, isValidModule } from '../lib/moduleValidation';

const selfchecks = await getCollection('selfchecks', (entry) => !entry.data.draft);

// Validate modules and log warnings
const validation = await validateModules();
logModuleWarnings(validation);

// Filter valid selfchecks only
const validSelfchecks = selfchecks.filter(sc => isValidModule(sc.data.module));

// Group by module
const byModule = new Map();
for (const module of moduleNames) {
  byModule.set(module, []);
}
for (const sc of validSelfchecks) {
  const list = byModule.get(sc.data.module) || [];
  list.push(sc);
  byModule.set(sc.data.module, list);
}

const base = import.meta.env.BASE_URL;
---

<CourseLayout title="自我检测">
  <div class="max-w-4xl mx-auto px-4 py-8">
    <header class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 mb-3">自我检测</h1>
      <p class="text-gray-600">
        通过主动回忆强化学习效果。点击卡片查看答案，测试自己对知识点的掌握程度。
        <span class="text-sm text-gray-500 block mt-1">基于认知科学：提取练习比重复阅读更能促进长期记忆</span>
      </p>
    </header>

    <!-- Module Filter -->
    <div class="mb-8">
      <div class="flex flex-wrap gap-2" id="module-filters">
        <button class="filter-btn active px-4 py-2 rounded-full text-sm font-medium transition-all bg-primary text-white" data-module="all">
          全部
        </button>
        {moduleNames.map(module => (
          <button
            class="filter-btn px-4 py-2 rounded-full text-sm font-medium transition-all bg-gray-100 text-gray-700 hover:bg-gray-200"
            data-module={module}
          >
            {module}
            <span class="ml-1 text-xs text-gray-500">({byModule.get(module)?.length || 0})</span>
          </button>
        ))}
      </div>
    </div>

    <!-- Progress -->
    <div class="mb-6 flex items-center justify-between text-sm text-gray-600">
      <span id="progress-text">已查看: 0 / {validSelfchecks.length}</span>
      <button id="reset-progress" class="text-primary hover:underline">重置进度</button>
    </div>

    <!-- Cards Grid -->
    <div class="grid gap-6" id="cards-container">
      {validSelfchecks.map((sc, index) => (
        <div
          class="selfcheck-card bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden"
          data-module={sc.data.module}
          data-index={index}
          data-slug={sc.slug}
        >
          <div class="card-inner">
            <!-- Front -->
            <div class="card-front p-6">
              <div class="flex items-start justify-between mb-4">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-50 text-blue-700">
                  {sc.data.module}
                </span>
                <span class="text-xs text-gray-400">#{index + 1}</span>
              </div>
              <h3 class="text-lg font-medium text-gray-900 mb-4">{sc.data.question}</h3>
              <button class="reveal-btn w-full py-3 px-4 bg-primary text-white rounded-lg font-medium hover:bg-primary-dark transition-colors flex items-center justify-center gap-2">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                </svg>
                显示答案
              </button>
            </div>

            <!-- Back -->
            <div class="card-back p-6 bg-gray-50 hidden">
              <div class="flex items-start justify-between mb-4">
                <span class="text-xs text-gray-500 uppercase tracking-wider font-medium">答案</span>
                <button class="close-btn p-1 text-gray-400 hover:text-gray-600">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                  </svg>
                </button>
              </div>
              <p class="text-gray-900 font-medium mb-4">{sc.data.answer}</p>

              <div class="border-t border-gray-200 pt-4 mt-4">
                <span class="text-xs text-gray-500 uppercase tracking-wider font-medium block mb-2">详细解释</span>
                <p class="text-gray-700 text-sm leading-relaxed">{sc.data.explanation}</p>
              </div>

              {sc.data.tags.length > 0 && (
                <div class="mt-4 flex flex-wrap gap-2">
                  {sc.data.tags.map(tag => (
                    <span class="px-2 py-1 bg-white rounded text-xs text-gray-600 border border-gray-200">{tag}</span>
                  ))}
                </div>
              )}

              <div class="mt-6 flex gap-3">
                <button class="confidence-btn flex-1 py-2 px-3 rounded-lg border-2 border-red-200 text-red-600 text-sm font-medium hover:bg-red-50 transition-colors" data-level="1">
                  不熟悉
                </button>
                <button class="confidence-btn flex-1 py-2 px-3 rounded-lg border-2 border-yellow-200 text-yellow-600 text-sm font-medium hover:bg-yellow-50 transition-colors" data-level="2">
                  一般
                </button>
                <button class="confidence-btn flex-1 py-2 px-3 rounded-lg border-2 border-green-200 text-green-600 text-sm font-medium hover:bg-green-50 transition-colors" data-level="3">
                  已掌握
                </button>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Empty State -->
    <div id="empty-state" class="hidden text-center py-12">
      <div class="text-6xl mb-4">🎉</div>
      <h3 class="text-xl font-semibold text-gray-900 mb-2">该模块暂无题目</h3>
      <p class="text-gray-600">请尝试选择其他模块</p>
    </div>
  </div>
</CourseLayout>

<script>
  // Module filtering
  const filterBtns = document.querySelectorAll('.filter-btn');
  const cards = document.querySelectorAll('.selfcheck-card');
  const emptyState = document.getElementById('empty-state');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      // Update active state
      filterBtns.forEach(b => {
        b.classList.remove('active', 'bg-primary', 'text-white');
        b.classList.add('bg-gray-100', 'text-gray-700');
      });
      btn.classList.add('active', 'bg-primary', 'text-white');
      btn.classList.remove('bg-gray-100', 'text-gray-700');

      // Filter cards
      const module = btn.dataset.module;
      let visibleCount = 0;

      cards.forEach(card => {
        if (module === 'all' || card.dataset.module === module) {
          card.classList.remove('hidden');
          visibleCount++;
        } else {
          card.classList.add('hidden');
        }
      });

      emptyState.classList.toggle('hidden', visibleCount > 0);
    });
  });

  // Card flip functionality
  cards.forEach(card => {
    const revealBtn = card.querySelector('.reveal-btn');
    const closeBtn = card.querySelector('.close-btn');
    const front = card.querySelector('.card-front');
    const back = card.querySelector('.card-back');

    revealBtn?.addEventListener('click', () => {
      front.classList.add('hidden');
      back.classList.remove('hidden');
      markAsViewed(card.dataset.slug);
    });

    closeBtn?.addEventListener('click', () => {
      back.classList.add('hidden');
      front.classList.remove('hidden');
    });
  });

  // Progress tracking
  const STORAGE_KEY = 'selfcheck-viewed';

  function getViewed(): Set<string> {
    const data = localStorage.getItem(STORAGE_KEY);
    return new Set(data ? JSON.parse(data) : []);
  }

  function markAsViewed(slug: string | null) {
    if (!slug) return;
    const viewed = getViewed();
    viewed.add(slug);
    localStorage.setItem(STORAGE_KEY, JSON.stringify([...viewed]));
    updateProgress();
  }

  function updateProgress() {
    const viewed = getViewed();
    const total = cards.length;
    const text = document.getElementById('progress-text');
    if (text) {
      text.textContent = `已查看: ${viewed.size} / ${total}`;
    }
  }

  document.getElementById('reset-progress')?.addEventListener('click', () => {
    localStorage.removeItem(STORAGE_KEY);
    updateProgress();
  });

  // Confidence buttons
  document.querySelectorAll('.confidence-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const card = btn.closest('.selfcheck-card');
      const buttons = card?.querySelectorAll('.confidence-btn');

      buttons?.forEach(b => {
        b.classList.remove('ring-2', 'ring-offset-2', 'ring-primary');
      });

      btn.classList.add('ring-2', 'ring-offset-2', 'ring-primary');

      // Store confidence level
      const slug = card?.dataset.slug;
      const level = btn.dataset.level;
      if (slug && level) {
        const key = 'selfcheck-confidence';
        const data = JSON.parse(localStorage.getItem(key) || '{}');
        data[slug] = level;
        localStorage.setItem(key, JSON.stringify(data));
      }
    });
  });

  // Initialize
  updateProgress();
</script>

<style>
  .card-back {
    display: none;
  }

  .card-back:not(.hidden) {
    display: block;
    animation: fadeIn 0.2s ease-out;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .filter-btn.active {
    background-color: var(--color-primary, #3b82f6);
    color: white;
  }
</style>

---
import CourseLayout from '../layouts/CourseLayout.astro';
import { getCollection } from 'astro:content';
import { materialsLabels, materialTypeLabels, pageTitles } from '../config';

const materials = await getCollection('materials');

const typeColors: Record<string, string> = {
  article: 'bg-green-100 text-green-700',
  video: 'bg-red-100 text-red-700',
  code: 'bg-purple-100 text-purple-700',
  tool: 'bg-orange-100 text-orange-700',
  book: 'bg-blue-100 text-blue-700',
};
---

<CourseLayout title={pageTitles.materials}>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl font-bold mb-4">{materialsLabels.pageTitle}</h1>
    <p class="text-text-muted mb-8">
      {materialsLabels.description}
    </p>

    <div class="grid gap-4">
      {materials.map(material => (
        <div class="bg-bg-secondary border border-border rounded-lg p-6">
          <div class="flex items-start justify-between mb-2">
            <div class="flex items-center gap-3">
              <span class={`px-2 py-1 rounded text-xs font-medium ${typeColors[material.data.type]}`}>
                {materialTypeLabels[material.data.type]}
              </span>
              {material.data.tags.map(tag => (
                <span class="text-xs text-text-muted">{materialsLabels.tagPrefix}{tag}</span>
              ))}
            </div>
          </div>

          <h3 class="text-lg font-semibold mb-2">
            {material.data.url ? (
              <a href={material.data.url} target="_blank" class="hover:text-primary">
                {material.data.title} ↗
              </a>
            ) : (
              material.data.title
            )}
          </h3>

          <p class="text-text-muted text-sm">{material.data.description}</p>
        </div>
      ))}
    </div>
  </div>
</CourseLayout>

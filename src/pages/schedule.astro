---
import CourseLayout from '../layouts/CourseLayout.astro';
import { getCollection } from 'astro:content';
import { scheduleLabels, pageTitles } from '../config';

const base = import.meta.env.BASE_URL || '/';
const lectures = await getCollection('lectures');
const assignments = await getCollection('assignments');

const sortedLectures = lectures
  .filter(l => !l.data.draft && l.data.week)
  .sort((a, b) => a.data.lectureNumber - b.data.lectureNumber);

const sortedAssignments = assignments
  .filter(a => !a.data.draft && a.data.week)
  .sort((a, b) => a.data.assignmentNumber - b.data.assignmentNumber);

// Build schedule dynamically from week field
const maxWeek = Math.max(
  ...sortedLectures.map(l => l.data.week || 0),
  ...sortedAssignments.map(a => a.data.week || 0)
);

const weeks = Array.from({ length: maxWeek }, (_, i) => {
  const week = i + 1;
  const weekLectures = sortedLectures.filter(l => l.data.week === week);
  const weekAssignment = sortedAssignments.find(a => a.data.week === week);
  return {
    week,
    lectures: weekLectures,
    assignment: weekAssignment || null
  };
});

function getLectureRef(lecture: typeof sortedLectures[0]) {
  return `${base}lectures/${lecture.id.replace('.md', '')}`;
}
---

<CourseLayout title={pageTitles.schedule}>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl font-bold mb-8">{scheduleLabels.pageTitle}</h1>

    <div class="space-y-4">
      {weeks.map(({ week, lectures: weekLectures, assignment }) => (
        <div class="flex gap-4 p-4 bg-bg-secondary rounded-lg border border-border">
          <div class="flex-shrink-0 w-16 text-center">
            <div class="text-2xl font-bold text-primary">{week}</div>
            <div class="text-xs text-text-muted">{scheduleLabels.weekSuffix}</div>
          </div>

          <div class="flex-1 space-y-3">
            {weekLectures.map(lecture => (
              <div class="flex items-center flex-wrap gap-2">
                <span class="px-2 py-1 bg-blue-100 text-blue-700 text-xs rounded">{scheduleLabels.courseBadge}</span>
                <a
                  href={getLectureRef(lecture)}
                  class="font-medium hover:text-primary"
                >
                  {lecture.data.title}
                </a>
                {lecture.data.slidevUrl && (
                  <a
                    href={lecture.data.slidevUrl}
                    class="inline-flex items-center gap-1.5 px-2.5 py-1 text-xs font-medium text-blue-700 bg-blue-50 hover:bg-blue-100 rounded-full transition-colors"
                    target="_blank"
                    rel="noopener noreferrer"
                    title={scheduleLabels.slidesTitle}
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <rect width="18" height="18" x="3" y="3" rx="2" ry="2"/>
                      <line x1="3" x2="21" y1="9" y2="9"/>
                      <line x1="9" x2="9" y1="21" y2="9"/>
                    </svg>
                    {scheduleLabels.slides}
                  </a>
                )}
              </div>
            ))}

            {assignment && (
              <div class="flex items-center flex-wrap gap-2">
                <span class="px-2 py-1 bg-amber-100 text-amber-700 text-xs rounded">{scheduleLabels.assignmentBadge}</span>
                <a
                  href={`${base}assignments/${assignment.id}`}
                  class="font-medium hover:text-primary"
                >
                  HW{assignment.data.assignmentNumber}: {assignment.data.title}
                </a>
                {assignment.data.dueDate && (
                  <span class="inline-flex items-center gap-1 text-xs text-slate-500">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="12" cy="12" r="10"/>
                      <polyline points="12 6 12 12 16 14"/>
                    </svg>
                    {assignment.data.dueDate.toLocaleDateString('zh-CN')}
                  </span>
                )}
                {assignment.data.downloadFile && (
                  <a
                    href={assignment.data.downloadFile}
                    class="inline-flex items-center gap-1.5 px-2.5 py-1 text-xs font-medium text-amber-700 bg-amber-50 hover:bg-amber-100 rounded-full transition-colors"
                    download
                    title={scheduleLabels.downloadTitle}
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                      <polyline points="7 10 12 15 17 10"/>
                      <line x1="12" x2="12" y1="15" y2="3"/>
                    </svg>
                    {scheduleLabels.download}
                  </a>
                )}
              </div>
            )}

            {weekLectures.length === 0 && !assignment && (
              <div class="text-text-muted italic">{scheduleLabels.emptyState}</div>
            )}
          </div>
        </div>
      ))}

      {weeks.length === 0 && (
        <div class="text-center text-text-muted py-12">
          {scheduleLabels.emptyStateHelp}
        </div>
      )}
    </div>
  </div>
</CourseLayout>

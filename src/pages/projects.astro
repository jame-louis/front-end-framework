---
import CourseLayout from '../layouts/CourseLayout.astro';
import { getCollection } from 'astro:content';
import { projectLabels, labels, pageTitles } from '../config';

const base = import.meta.env.BASE_URL || '/';
const projects = await getCollection('projects');
const sortedProjects = projects
  .filter(p => !p.data.draft)
  .sort((a, b) => a.data.projectNumber - b.data.projectNumber);
---

<CourseLayout title={pageTitles.projects}>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl font-bold mb-4">{projectLabels.pageTitle}</h1>
    <p class="text-text-muted mb-8">
      {projectLabels.description}
    </p>

    <div class="space-y-6">
      {sortedProjects.map(project => (
        <div class="bg-bg-secondary border border-border rounded-lg p-6">
          <div class="flex items-start justify-between mb-4">
            <div>
              <span class="text-sm text-primary font-medium">
                {projectLabels.projectLabel} {project.data.projectNumber}
              </span>
              <h2 class="text-xl font-semibold mt-1">{project.data.title}</h2>
            </div>
            <span class="px-3 py-1 bg-blue-100 text-blue-700 rounded-full text-sm">
              {project.data.totalPoints}{projectLabels.pointsSuffix}
            </span>
          </div>

          <p class="text-text-muted mb-4">{project.data.description}</p>

          {project.data.milestones.length > 0 && (
            <div class="mb-4">
              <h3 class="font-medium mb-2">{projectLabels.milestonesTitle}</h3>
              <ul class="space-y-2">
                {project.data.milestones.map((milestone, i) => (
                  <li class="flex items-start gap-2 text-sm">
                    <span class="text-primary font-medium">{i + 1}.</span>
                    <div>
                      <div class="font-medium">{milestone.title}</div>
                      <div class="text-text-muted">{milestone.description}</div>
                    </div>
                  </li>
                ))}
              </ul>
            </div>
          )}

          <a
            href={`${base}projects/${project.id}`}
            class="inline-flex items-center text-primary hover:text-primary-dark font-medium"
          >
            {labels.viewDetails}
          </a>
        </div>
      ))}
    </div>
  </div>
</CourseLayout>

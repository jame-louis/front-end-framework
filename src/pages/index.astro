---
import CourseLayout from '../layouts/CourseLayout.astro';
import { getCollection } from 'astro:content';
import {
  courseInfo,
  courseStats,
  homeActions,
  courseModules,
  lectureLabels,
  labels,
  infoSectionLabels,
  pageTitles,
} from '../config';

const base = import.meta.env.BASE_URL || '/';

const lectures = await getCollection('lectures');
const sortedLectures = lectures
  .filter(l => !l.data.draft)
  .sort((a, b) => a.data.lectureNumber - b.data.lectureNumber);

const assignments = await getCollection('assignments');
const assignmentsCount = assignments.filter(a => !a.data.draft).length;

const displayModules = courseModules.display.map((m, i) => ({
  ...m,
  icon: String(i + 1).padStart(2, '0'),
  color: i === 0 ? 'bg-blue-500' : 'bg-green-500',
}));
---

<CourseLayout title={pageTitles.home}>
  <!-- Hero Section -->
  <section class="bg-gradient-to-b from-bg-secondary to-white py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl lg:text-5xl font-bold text-text mb-6">
        {courseInfo.name}
      </h1>
      <p class="text-lg lg:text-xl text-text-muted max-w-2xl mx-auto mb-8">
        {courseInfo.description}
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={`${base}${homeActions.primary.href.replace(/^\//, '')}`}
          class="inline-flex items-center justify-center px-6 py-3 bg-primary text-white font-medium rounded-lg hover:bg-primary-dark transition-colors"
        >
          {homeActions.primary.label}
        </a>
        <a
          href={`${base}${homeActions.secondary.href.replace(/^\//, '')}`}
          class="inline-flex items-center justify-center px-6 py-3 bg-white text-text font-medium rounded-lg border border-border hover:bg-bg-secondary transition-colors"
        >
          {homeActions.secondary.label}
        </a>
      </div>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="py-12 border-b border-border">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="text-center p-6 bg-bg-secondary rounded-lg">
          <div class="text-3xl font-bold text-primary">{sortedLectures.length}</div>
          <div class="text-text-muted mt-1">{courseStats.lectures.suffix}</div>
        </div>
        <div class="text-center p-6 bg-bg-secondary rounded-lg">
          <div class="text-3xl font-bold text-primary">{courseModules.names.length}</div>
          <div class="text-text-muted mt-1">{courseStats.modules.suffix}</div>
        </div>
        <div class="text-center p-6 bg-bg-secondary rounded-lg">
          <div class="text-3xl font-bold text-primary">{assignmentsCount}</div>
          <div class="text-text-muted mt-1">{courseStats.assignments.suffix}</div>
        </div>
        <div class="text-center p-6 bg-bg-secondary rounded-lg">
          <div class="text-3xl font-bold text-primary">{courseStats.duration.value}</div>
          <div class="text-text-muted mt-1">{courseStats.duration.suffix}</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Modules Section -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-center mb-12">{lectureLabels.contentSectionTitle}</h2>
      <div class="grid md:grid-cols-3 gap-6">
        {displayModules.map((module) => (
          <div class="bg-white border border-border rounded-lg p-6 hover:shadow-md transition-shadow">
            <div class={`inline-flex items-center justify-center w-12 h-12 rounded-lg ${module.color} text-white font-bold mb-4`}>
              {module.icon}
            </div>
            <h3 class="text-lg font-semibold mb-2">{module.name}</h3>
            <p class="text-text-muted text-sm">
              {lectureLabels.moduleCountTemplate.replace('{count}', String(module.count))}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Recent Lectures -->
  <section class="py-16 bg-bg-secondary">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center mb-8">
        <h2 class="text-2xl font-bold">{lectureLabels.sectionTitle}</h2>
        <a href={`${base}lectures`} class="text-primary hover:text-primary-dark font-medium">
          {labels.viewAll}
        </a>
      </div>
      <div class="grid gap-4">
        {sortedLectures.slice(0, 6).map(lecture => (
          <a
            href={`${base}lectures/${lecture.id.replace('.md', '')}`}
            class="flex items-center gap-4 p-4 bg-white rounded-lg border border-border hover:border-primary hover:shadow-sm transition-all"
          >
            <span class="flex-shrink-0 w-10 h-10 bg-primary text-white rounded-md flex items-center justify-center font-semibold">
              {lecture.data.lectureNumber}
            </span>
            <span class="font-medium">{lecture.data.title}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Course Info -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-bg-secondary rounded-lg p-8">
        <h2 class="text-xl font-bold mb-6">{infoSectionLabels.courseInfoTitle}</h2>
        <div class="grid md:grid-cols-3 gap-6 text-sm">
          <div>
            <h4 class="font-semibold text-text-muted mb-2">{infoSectionLabels.textbookLabel}</h4>
            <p>{courseInfo.textbook}</p>
          </div>
          <div>
            <h4 class="font-semibold text-text-muted mb-2">{infoSectionLabels.prerequisitesLabel}</h4>
            <p>{courseInfo.prerequisites}</p>
          </div>
          <div>
            <h4 class="font-semibold text-text-muted mb-2">{infoSectionLabels.assessmentLabel}</h4>
            <p>{courseInfo.assessment}</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</CourseLayout>

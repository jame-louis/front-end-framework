---
import CourseLayout from '../layouts/CourseLayout.astro';
import { getCollection } from 'astro:content';
import { sidebarConfig, courseObjectives, syllabusLabels, labels, pageTitles } from '../config';

const base = import.meta.env.BASE_URL || '/';
const lectures = await getCollection('lectures');
const sortedLectures = lectures
  .filter(l => !l.data.draft)
  .sort((a, b) => a.data.lectureNumber - b.data.lectureNumber);

const moduleDescriptions: Record<string, string> = {
  'JavaScript基础': 'JavaScript核心语法、DOM操作、事件处理、数据组织与持久化',
  'Bootstrap框架': '响应式布局、Bootstrap组件与工具类',
  'Vue.js框架': 'Vue 3基础、组件开发、路由管理、状态管理',
};
---

<CourseLayout title={pageTitles.syllabus}>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl font-bold mb-8">{pageTitles.syllabus}</h1>

    <!-- Course Overview -->
    <section class="mb-12 bg-bg-secondary rounded-lg p-6">
      <h2 class="text-xl font-semibold mb-4">{syllabusLabels.objectivesTitle}</h2>
      <ul class="space-y-2">
        {courseObjectives.map(obj => (
          <li class="flex items-start gap-2">
            <span class="text-primary mt-1">✓</span>
            <span>{obj}</span>
          </li>
        ))}
      </ul>
    </section>

    <!-- Modules -->
    <section class="mb-12">
      <h2 class="text-xl font-semibold mb-6">{syllabusLabels.modulesTitle}</h2>
      <div class="grid md:grid-cols-3 gap-6">
        {sidebarConfig.modules.map(module => (
          <div class="bg-white border border-border rounded-lg p-6">
            <h3 class="font-semibold text-primary mb-2">{module.name}</h3>
            <p class="text-sm text-text-muted mb-4">{moduleDescriptions[module.name]}</p>
            <div class="text-sm">
              <span class="font-medium">{syllabusLabels.courseRangeLabel}</span> {syllabusLabels.lectureRangeTemplate.replace('{start}', String(module.range[0])).replace('{end}', String(module.range[1]))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Lecture Schedule -->
    <section>
      <h2 class="text-xl font-semibold mb-6">{syllabusLabels.scheduleTitle}</h2>
      <div class="space-y-4">
        {sortedLectures.map(lecture => (
          <div class="flex items-center gap-4 p-4 bg-bg-secondary rounded-lg border border-border">
            <span class="flex-shrink-0 w-12 h-12 bg-primary text-white rounded-md flex items-center justify-center font-bold">
              {lecture.data.lectureNumber}
            </span>
            <div class="flex-1 min-w-0">
              <h4 class="font-medium truncate">{lecture.data.title}</h4>
              <div class="flex flex-wrap gap-2 text-sm text-text-muted mt-1">
                <span>{lecture.data.module}</span>
                {lecture.data.duration && <span>· {lecture.data.duration}</span>}
              </div>
            </div>
            <a
              href={`${base}lectures/${lecture.id.replace('.md', '')}`}
              class="text-sm text-primary hover:text-primary-dark font-medium"
            >
              {labels.viewLecture}
            </a>
          </div>
        ))}
      </div>
    </section>
  </div>
</CourseLayout>

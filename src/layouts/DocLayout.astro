---
import CourseLayout from './CourseLayout.astro';
import Sidebar from '../components/navigation/Sidebar.astro';
import TOCSidebar from '../components/content/TOCSidebar.astro';

interface Props {
  title: string;
  description?: string;
  headings?: Array<{ depth: number; slug: string; text: string }>;
  currentSlug?: string;
}

const { title, description, headings = [], currentSlug } = Astro.props;
---

<CourseLayout title={title} description={description}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 sm:py-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-4 lg:gap-8">
      <!-- Left Sidebar: Navigation (Desktop) -->
      <aside class="hidden lg:block lg:col-span-3">
        <div class="sticky top-20">
          <Sidebar currentSlug={currentSlug} />
        </div>
      </aside>

      <!-- Mobile: Compact Navigation -->
      <div class="lg:hidden -mx-4 px-4 pb-4 border-b border-border overflow-x-auto">
        <div class="flex gap-2 min-w-max">
          <a href={`${import.meta.env.BASE_URL}lectures`} class="text-sm px-3 py-1.5 bg-bg-secondary rounded-full text-text-muted hover:text-primary whitespace-nowrap">
            全部课程
          </a>
          <a href={`${import.meta.env.BASE_URL}syllabus`} class="text-sm px-3 py-1.5 bg-bg-secondary rounded-full text-text-muted hover:text-primary whitespace-nowrap">
            课程大纲
          </a>
        </div>
      </div>

      <!-- Main Content -->
      <main class="lg:col-span-7 min-w-0">
        <!-- Mobile: Inline TOC -->
        {headings.length > 0 && (
          <div class="lg:hidden mb-6 p-4 bg-bg-secondary rounded-lg border border-border">
            <p class="font-medium text-text-muted mb-2 text-sm">本页目录</p>
            <nav class="space-y-1">
              {headings.filter(h => h.depth <= 3).map(heading => (
                <a
                  href={`#${heading.slug}`}
                  class={`block text-sm text-text-muted hover:text-primary transition-colors ${
                    heading.depth === 2 ? '' : 'ml-3'
                  }`}
                >
                  {heading.text}
                </a>
              ))}
            </nav>
          </div>
        )}
        <article class="prose-custom">
          <slot />
        </article>
      </main>

      <!-- Right Sidebar: TOC (Desktop) -->
      {headings.length > 0 && (
        <aside class="hidden lg:block lg:col-span-2">
          <div class="sticky top-20">
            <TOCSidebar headings={headings} />
          </div>
        </aside>
      )}
    </div>
  </div>

</CourseLayout>

---
import CourseLayout from './CourseLayout.astro';
import Sidebar from '../components/navigation/Sidebar.astro';
import TOCSidebar from '../components/content/TOCSidebar.astro';

interface Props {
  title: string;
  description?: string;
  headings?: Array<{ depth: number; slug: string; text: string }>;
  currentSlug?: string;
}

const { title, description, headings = [], currentSlug } = Astro.props;
---

<CourseLayout title={title} description={description}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 sm:py-8">
    <!-- Mobile: Floating TOC Button -->
    {headings.length > 0 && (
      <button
        id="mobile-toc-btn"
        class="lg:hidden fixed bottom-4 right-4 z-50 w-12 h-12 bg-primary text-white rounded-full shadow-lg flex items-center justify-center"
        aria-label="目录"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7" />
        </svg>
      </button>
    )}

    <!-- Mobile: TOC Drawer -->
    {headings.length > 0 && (
      <div
        id="mobile-toc-drawer"
        class="lg:hidden fixed inset-0 z-40 hidden"
      >
        <div class="absolute inset-0 bg-black/50" id="mobile-toc-overlay"></div>
        <div class="absolute right-0 top-0 bottom-0 w-64 bg-white shadow-xl p-4 overflow-y-auto">
          <div class="flex items-center justify-between mb-4 pb-2 border-b border-border">
            <h3 class="font-semibold">本页目录</h3>
            <button id="mobile-toc-close" class="p-1 hover:bg-bg-secondary rounded">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
          </div>
          <TOCSidebar headings={headings} />
        </div>
      </div>
    )}

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-4 lg:gap-8">
      <!-- Left Sidebar: Navigation (Desktop) -->
      <aside class="hidden lg:block lg:col-span-3">
        <div class="sticky top-20">
          <Sidebar currentSlug={currentSlug} />
        </div>
      </aside>

      <!-- Mobile: Compact Navigation -->
      <div class="lg:hidden -mx-4 px-4 pb-4 border-b border-border overflow-x-auto">
        <div class="flex gap-2 min-w-max">
          <a href="/lectures" class="text-sm px-3 py-1.5 bg-bg-secondary rounded-full text-text-muted hover:text-primary whitespace-nowrap">
            全部课程
          </a>
          <a href="/syllabus" class="text-sm px-3 py-1.5 bg-bg-secondary rounded-full text-text-muted hover:text-primary whitespace-nowrap">
            课程大纲
          </a>
          <a href="/schedule" class="text-sm px-3 py-1.5 bg-bg-secondary rounded-full text-text-muted hover:text-primary whitespace-nowrap">
            课程表
          </a>
        </div>
      </div>

      <!-- Main Content -->
      <main class="lg:col-span-7 min-w-0">
        <article class="prose-custom">
          <slot />
        </article>
      </main>

      <!-- Right Sidebar: TOC (Desktop) -->
      {headings.length > 0 && (
        <aside class="hidden lg:block lg:col-span-2">
          <div class="sticky top-20">
            <TOCSidebar headings={headings} />
          </div>
        </aside>
      )}
    </div>
  </div>

  <script>
    // Mobile TOC toggle
    const tocBtn = document.getElementById('mobile-toc-btn');
    const tocDrawer = document.getElementById('mobile-toc-drawer');
    const tocOverlay = document.getElementById('mobile-toc-overlay');
    const tocClose = document.getElementById('mobile-toc-close');

    function openToc() {
      tocDrawer?.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }

    function closeToc() {
      tocDrawer?.classList.add('hidden');
      document.body.style.overflow = '';
    }

    tocBtn?.addEventListener('click', openToc);
    tocOverlay?.addEventListener('click', closeToc);
    tocClose?.addEventListener('click', closeToc);
  </script>
</CourseLayout>

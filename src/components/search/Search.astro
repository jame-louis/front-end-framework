<div id="search-modal" class="fixed inset-0 z-50 hidden" aria-modal="true" role="dialog">
  <!-- Overlay -->
  <div id="search-overlay" class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>

  <!-- Modal Content -->
  <div class="absolute inset-x-4 top-[10%] sm:top-[15%] sm:inset-x-auto sm:left-1/2 sm:-translate-x-1/2 sm:w-full sm:max-w-2xl">
    <div class="bg-white rounded-xl shadow-2xl overflow-hidden border border-border">
      <!-- Search Input -->
      <div class="flex items-center gap-3 px-4 py-3 border-b border-border">
        <svg class="w-5 h-5 text-text-muted flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <input
          id="search-input"
          type="text"
          placeholder="搜索课程内容..."
          class="flex-1 bg-transparent outline-none text-text placeholder:text-text-muted"
          autocomplete="off"
        />
        <kbd class="hidden sm:inline-flex items-center gap-1 px-2 py-1 bg-bg-secondary rounded text-xs text-text-muted border border-border">
          <span>ESC</span>
        </kbd>
      </div>

      <!-- Results -->
      <div id="search-results" class="max-h-[60vh] overflow-y-auto p-2">
        <div id="search-empty" class="p-8 text-center text-text-muted text-sm">
          输入关键词开始搜索...
        </div>
        <div id="search-loading" class="hidden p-8 text-center text-text-muted text-sm">
          搜索中...
        </div>
        <div id="search-no-results" class="hidden p-8 text-center text-text-muted text-sm">
          未找到相关结果
        </div>
        <div id="search-list" class="hidden space-y-1"></div>
      </div>

      <!-- Footer -->
      <div class="px-4 py-2 bg-bg-secondary border-t border-border text-xs text-text-muted flex items-center justify-between">
        <span>按 Enter 打开</span>
        <span class="flex items-center gap-2">
          <span class="flex items-center gap-1">
            <kbd class="px-1.5 py-0.5 bg-white rounded border border-border">↑</kbd>
            <kbd class="px-1.5 py-0.5 bg-white rounded border border-border">↓</kbd>
            导航
          </span>
        </span>
      </div>
    </div>
  </div>
</div>

<script>
  import Fuse from 'fuse.js';

  const categoryLabels: Record<string, { label: string; color: string }> = {
    lectures: { label: '讲义', color: 'bg-blue-100 text-blue-700' },
    assignments: { label: '作业', color: 'bg-orange-100 text-orange-700' },
    pages: { label: '页面', color: 'bg-gray-100 text-gray-700' },
  };

  let fuse: Fuse<unknown> | null = null;
  let selectedIndex = -1;
  let currentResults: Fuse.FuseResult<unknown>[] = [];

  const modal = document.getElementById('search-modal');
  const overlay = document.getElementById('search-overlay');
  const input = document.getElementById('search-input') as HTMLInputElement;
  const emptyState = document.getElementById('search-empty');
  const loadingState = document.getElementById('search-loading');
  const noResultsState = document.getElementById('search-no-results');
  const list = document.getElementById('search-list');

  async function initFuse(): Promise<boolean> {
    if (fuse) return true;
    try {
      const base = import.meta.env.BASE_URL || '/';
      const indexUrl = base.endsWith('/') ? `${base}search-index.json` : `${base}/search-index.json`;
      const res = await fetch(indexUrl);
      if (!res.ok) throw new Error('Failed to fetch search index');
      const data = await res.json();
      fuse = new Fuse(data, {
        keys: ['title', 'description', 'content'],
        threshold: 0.3,
      });
      return true;
    } catch (e) {
      console.error('Search init error:', e);
      return false;
    }
  }

  function openModal() {
    modal?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    setTimeout(() => input?.focus(), 50);
    initFuse();
  }

  function closeModal() {
    modal?.classList.add('hidden');
    document.body.style.overflow = '';
    if (input) input.value = '';
    resetResults();
  }

  function resetResults() {
    selectedIndex = -1;
    emptyState?.classList.remove('hidden');
    loadingState?.classList.add('hidden');
    noResultsState?.classList.add('hidden');
    list?.classList.add('hidden');
    if (list) list.innerHTML = '';
  }

  function showState(state: 'empty' | 'loading' | 'no-results' | 'list') {
    emptyState?.classList.toggle('hidden', state !== 'empty');
    loadingState?.classList.toggle('hidden', state !== 'loading');
    noResultsState?.classList.toggle('hidden', state !== 'no-results');
    list?.classList.toggle('hidden', state !== 'list');
  }

  function getCategoryFromUrl(url: string): { label: string; color: string } {
    if (url.includes('/lectures/')) return categoryLabels.lectures;
    if (url.includes('/assignments/')) return categoryLabels.assignments;
    return categoryLabels.pages;
  }

  function renderResults(results: Fuse.FuseResult<unknown>[]) {
    if (!list) return;
    list.innerHTML = '';
    const items = results.slice(0, 10);

    items.forEach((result, i) => {
      const item = result.item as { title: string; description: string; content: string; slug: string };
      const el = document.createElement('a');
      el.href = item.slug;
      const isSelected = i === selectedIndex;
      const category = getCategoryFromUrl(item.slug);

      el.className = `block px-3 py-2.5 rounded-lg transition-colors ${isSelected ? 'bg-bg-secondary' : 'hover:bg-bg-secondary'}`;
      el.innerHTML = `
        <div class="flex items-center gap-2">
          <span class="text-[10px] px-1.5 py-0.5 rounded font-medium ${category.color}">${category.label}</span>
          <span class="font-medium text-sm text-text line-clamp-1">${item.title || '无标题'}</span>
        </div>
        <div class="text-xs text-text-muted mt-1 line-clamp-2">${item.description || item.content?.slice(0, 120) || ''}</div>
      `;
      el.addEventListener('click', closeModal);
      list.appendChild(el);
    });

    showState('list');
  }

  function performSearch(query: string) {
    if (!query.trim()) {
      resetResults();
      return;
    }

    showState('loading');
    if (!fuse) {
      showState('empty');
      return;
    }

    const results = fuse.search(query);
    currentResults = results;

    if (results.length === 0) {
      showState('no-results');
    } else {
      selectedIndex = 0;
      renderResults(results);
    }
  }

  // Debounced search
  let debounceTimer: ReturnType<typeof setTimeout>;
  input?.addEventListener('input', (e) => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => performSearch((e.target as HTMLInputElement).value), 150);
  });

  // Keyboard navigation
  input?.addEventListener('keydown', (e) => {
    if (currentResults.length === 0) return;

    if (e.key === 'ArrowDown') {
      e.preventDefault();
      selectedIndex = Math.min(selectedIndex + 1, Math.min(currentResults.length - 1, 9));
      renderResults(currentResults);
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      selectedIndex = Math.max(selectedIndex - 1, 0);
      renderResults(currentResults);
    } else if (e.key === 'Enter') {
      e.preventDefault();
      const items = list?.querySelectorAll('a');
      if (selectedIndex >= 0 && items && items[selectedIndex]) {
        items[selectedIndex].click();
      }
    }
  });

  // Close handlers
  overlay?.addEventListener('click', closeModal);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      openModal();
    }
  });

  // Expose open function globally
  (window as any).openSearchModal = openModal;
</script>

---
import { footerConfig, courseInfo } from '../config';

const currentYear = new Date().getFullYear();
---

<footer class="border-t border-border bg-bg-secondary">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="text-center text-text-muted text-sm">
      <p>{footerConfig.text}</p>
      <p class="mt-1">&copy; {currentYear} {footerConfig.copyright}. All rights reserved.</p>
    </div>
  </div>
</footer>
